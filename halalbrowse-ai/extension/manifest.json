{
  "manifest_version": 3,
  "name": "HalalBrowse AI",
  "version": "0.1.0",
  "description": "Privacy-first halal content filtering for Chrome and Firefox.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "HalalBrowse AI",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
